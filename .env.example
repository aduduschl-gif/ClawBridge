# ClawBridge Environment Variables
# Copy this to .env.local for local development

# Note: Most configuration happens in the browser Settings page.
# These are only needed for server-side operations or legacy setups.

# PostgreSQL (optional - can be configured in Settings instead)
# DATABASE_URL=postgresql://user:password@localhost:5432/clawbridge

# OpenClaw Gateway (optional - can be configured in Settings instead)
# OPENCLAW_GATEWAY_URL=http://localhost:18789

# API Key for external access (optional)
# API_KEY=your-secure-api-key

# Node environment
NODE_ENV=development
